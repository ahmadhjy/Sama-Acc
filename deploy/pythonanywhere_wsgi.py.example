# =============================================================================
# PythonAnywhere WSGI — Sama Accounting (Samatours2026 + PostgreSQL)
# =============================================================================
# Web tab → WSGI configuration file → paste and fill YOUR_POSTGRES_PASSWORD
# =============================================================================

import os
import sys

PROJECT_HOME = "/home/Samatours2026/Sama-Acc"
if PROJECT_HOME not in sys.path:
    sys.path.insert(0, PROJECT_HOME)

os.environ["DJANGO_SETTINGS_MODULE"] = "config.settings.production"
os.environ["DJANGO_SECRET_KEY"] = "YOUR_LONG_RANDOM_SECRET_KEY"
os.environ["DJANGO_ALLOWED_HOSTS"] = "Samatours2026.pythonanywhere.com"
os.environ["DJANGO_CSRF_TRUSTED_ORIGINS"] = "https://Samatours2026.pythonanywhere.com"
os.environ["DJANGO_DEBUG"] = "False"
os.environ["DJANGO_TIME_ZONE"] = "Asia/Beirut"

# PostgreSQL — copy Host, Database name, User, Password from PythonAnywhere → Databases
os.environ["DJANGO_DB_ENGINE"] = "postgresql"
os.environ["DJANGO_DB_NAME"] = "YOUR_POSTGRES_DATABASE_NAME"
os.environ["DJANGO_DB_USER"] = "YOUR_POSTGRES_USERNAME"
os.environ["DJANGO_DB_PASSWORD"] = "YOUR_POSTGRES_PASSWORD"
os.environ["DJANGO_DB_HOST"] = "YOUR_POSTGRES_HOST"
os.environ["DJANGO_DB_PORT"] = "15298"

from django.core.wsgi import get_wsgi_application

application = get_wsgi_application()
