# One-time setup on PythonAnywhere:
#   cp deploy/production.env.example deploy/production.env
#   nano deploy/production.env
#
# Copy DJANGO_SECRET_KEY and DJANGO_DB_PASSWORD from your ERP WSGI file
# (Web tab → WSGI configuration for samatours2026.pythonanywhere.com).
# Wrap secrets in single quotes if they contain special characters.
# Do not commit production.env to git.

DJANGO_SECRET_KEY='replace-with-your-secret-key'
DJANGO_ALLOWED_HOSTS=samatours2026.pythonanywhere.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://samatours2026.pythonanywhere.com
DJANGO_DEBUG=False
DJANGO_TIME_ZONE=Asia/Beirut

# PostgreSQL — ERP database (NOT sama_website — that is the marketing site)
DJANGO_DB_ENGINE=postgresql
DJANGO_DB_NAME=sama_acc
DJANGO_DB_USER=sama_app
DJANGO_DB_PASSWORD='replace-with-db-password'
DJANGO_DB_HOST=Samatours2026-5298.postgres.pythonanywhere-services.com
DJANGO_DB_PORT=15298

# Optional — auto-reload after deploy. Path from Web tab → ERP WSGI file link.
# PA_WSGI_FILE=/var/www/samatours2026_pythonanywhere_com_wsgi.py
