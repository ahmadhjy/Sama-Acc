# Copy to .env for local overrides (never commit .env to GitHub).
# On PythonAnywhere, set these in the Web → WSGI file instead (see DEPLOY_PYTHONANYWHERE.md).

# Required in production
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=yourusername.pythonanywhere.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourusername.pythonanywhere.com

# Production flags
DJANGO_DEBUG=False
DJANGO_TIME_ZONE=Asia/Beirut

# Database — SQLite (simplest; fine for small teams)
DJANGO_DB_ENGINE=sqlite
# DJANGO_DB_PATH=/home/yourusername/Sama-Accounting/db.sqlite3

# Database — PostgreSQL (PythonAnywhere paid plan)
# DJANGO_DB_ENGINE=postgresql
# DJANGO_DB_NAME=your_postgres_db_name
# DJANGO_DB_USER=your_postgres_user
# DJANGO_DB_PASSWORD=your-postgres-password
# DJANGO_DB_HOST=your-host.postgres.pythonanywhere-services.com
# DJANGO_DB_PORT=5432

# Database — MySQL (alternative on PythonAnywhere)
# DJANGO_DB_ENGINE=mysql
# DJANGO_DB_NAME=yourusername$sama
# DJANGO_DB_USER=yourusername
# DJANGO_DB_PASSWORD=your-mysql-password
# DJANGO_DB_HOST=yourusername.mysql.pythonanywhere-services.com
# DJANGO_DB_PORT=3306

# Optional paths (defaults are fine on PythonAnywhere)
# DJANGO_MEDIA_ROOT=/home/yourusername/Sama-Accounting/media

# Company branding (optional — also editable in Admin → Company branding)
# COMPANY_LEGAL_NAME=Sama Tours
# COMPANY_EMAIL=info@samatourslb.com
